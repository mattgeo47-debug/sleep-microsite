{
  "functions": {
    "api/proxy.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/lookup.js": {
      "maxDuration": 30,
      "memory": 256
    },
    "api/leaderboard.js": {
      "maxDuration": 30,
      "memory": 256
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
